{
  "name": "@ledgerhq/wallet-api-manifest-validator",
  "version": "0.7.28",
  "description": "This package checks if your manifest.json file meets the requirements for Ledger wallet App manifest submission.",
  "license": "MIT",
  "main": "lib/index.js",
  "module": "lib-es/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "/lib",
    "/lib-es",
    "/bin"
  ],
  "scripts": {
    "build": "rm -rf bin/* lib/* lib-es/* && tsc -p prod.tsconfig.json && tsc -p prod-esm.tsconfig.json",
    "format:check": "prettier --check \"src\" \"tests\"",
    "format:fix": "prettier --write \"src\"  \"tests\"",
    "lint": "eslint --cache \"src\" \"tests\"",
    "lint:fix": "eslint --cache --fix \"src\" \"tests\"",
    "test": "jest"
  },
  "devDependencies": {
    "@ledgerhq/jest-shared-config": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@ledgerhq/cryptoassets": "^13.49.0",
    "@ledgerhq/types-cryptoassets": "^7.37.0",
    "@ledgerhq/types-devices": "^6.31.0",
    "@ledgerhq/wallet-api-core": "workspace:*",
    "ajv": "^8.20.0",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.1"
  }
}
